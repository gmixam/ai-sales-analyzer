COMPOSE_PROJECT_NAME=asa
# asa = ai-sales-analyzer, all containers will get the asa_ prefix

POSTGRES_DB=ai_sales_analyzer
POSTGRES_USER=asa_app
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://asa_app:CHANGE_ME@asa_postgres:5432/ai_sales_analyzer

REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@asa_redis:6379/0

OPENAI_API_KEY=sk-...
OPENAI_MODEL_CLASSIFY=gpt-4o-mini
OPENAI_MODEL_ANALYZE=gpt-4o
OPENAI_MODEL_STT=whisper-1
OPENAI_API_KEY_STT_MAIN=sk-...
OPENAI_API_KEY_LLM1_MAIN=sk-...
OPENAI_API_KEY_LLM2_MAIN=sk-...

ASSEMBLYAI_API_KEY=...
ASSEMBLYAI_LANGUAGE=ru

STT_PROVIDER=assemblyai
MANUAL_LIVE_STT_PROVIDER=
STT_LANGUAGE=ru

AI_STT_ROUTING_POLICY=fixed
AI_STT_PROVIDERS_JSON=
AI_STT_FIXED_ACCOUNT_ALIAS=
AI_STT_FORCE_ACCOUNT_ALIAS=

AI_LLM1_ROUTING_POLICY=fixed
AI_LLM1_PROVIDERS_JSON=
AI_LLM1_FIXED_ACCOUNT_ALIAS=
AI_LLM1_FORCE_ACCOUNT_ALIAS=

AI_LLM2_ROUTING_POLICY=fixed
AI_LLM2_PROVIDERS_JSON=
AI_LLM2_FIXED_ACCOUNT_ALIAS=
AI_LLM2_FORCE_ACCOUNT_ALIAS=

ONLINEPBX_DOMAIN=yourcompany
ONLINEPBX_API_KEY=...
ONLINEPBX_API_BASE_URL=
ONLINEPBX_CDR_URL=

BITRIX24_WEBHOOK_URL=https://yourcompany.bitrix24.ru/rest/1/xxx/
BITRIX24_READONLY_ENABLED=true
BITRIX24_TARGET_DEPARTMENT_IDS=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...
SMTP_FROM=noreply@...

TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID_ROP=...
TEST_DELIVERY_TELEGRAM_CHAT_ID=
TEST_DELIVERY_EMAIL_TO=

NGINX_HTTP_PORT=8081
NGINX_HTTPS_PORT=8444
FLOWER_PORT=5556
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME

APP_ENV=production
LOG_LEVEL=INFO

MANUAL_PILOT_ENABLED=false
MANUAL_PILOT_EXTENSIONS=
MANUAL_PILOT_PHONES=
MANUAL_PILOT_EXTERNAL_IDS=
MANUAL_PILOT_MAX_CALLS=1

CALLS_MIN_DURATION_SEC=180
CALLS_MAX_DAILY_PER_MANAGER=20
CALLS_WEEKLY_PACK_SIZE=15
